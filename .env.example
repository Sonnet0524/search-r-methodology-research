# ============================================
# SEARCH-R 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入你的实际配置
# 注意：.env 文件已在 .gitignore 中，不会被提交

# ============================================
# 百度API统一配置
# ============================================
# Token来源: 百度千帆平台 / AI Studio
# 获取地址: https://aistudio.baidu.com/account/accessToken

# 百度统一API Key（用于所有百度服务）
BAIDU_API_KEY=your_baidu_api_key_here

# ============================================
# PaddleOCR API配置
# ============================================
# Token来源: https://aistudio.baidu.com/paddleocr/task

# PaddleOCR统一Token（与BAIDU_API_KEY相同）
PADDLEOCR_ACCESS_TOKEN=your_paddleocr_token_here

# PaddleOCR 同步API（用户专属URL - 需要从任务页面获取）
# 获取地址: https://aistudio.baidu.com/paddleocr/task
PADDLEOCR_OCR_API_URL=https://your-instance.aistudio-app.com/ocr
PADDLEOCR_DOC_PARSING_API_URL=https://your-instance.aistudio-app.com/layout-parsing

# PaddleOCR 异步API（公共URL - 无需修改）
PADDLEOCR_ASYNC_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs

# 超时设置（秒）
PADDLEOCR_OCR_TIMEOUT=120
PADDLEOCR_DOC_PARSING_TIMEOUT=600

# ============================================
# 可选配置
# ============================================
# 其他服务的API Key可以在这里添加
